{
  "name": "apna-rasoi",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server.js",
    "lint": "next lint",
    "test": "jest --testPathPatterns=\"unit|integration|component\"",
    "test:unit": "jest --testPathPatterns=\"unit\" --verbose",
    "test:integration": "jest --testPathPatterns=\"integration\" --verbose",
    "test:component": "jest --testPathPatterns=\"component\" --verbose",
    "test:coverage": "jest --testPathPatterns=\"unit|integration|component\" --coverage",
    "test:watch": "jest --testPathPatterns=\"unit|integration|component\" --watch",
    "test:ci": "jest --testPathPatterns=\"unit|integration|component\" --coverage --ci --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.0.1",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.14.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.0",
    "next": "^14.2.0",
    "nodemailer": "^6.9.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io": "^4.7.4",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "msw": "^2.13.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}

{\n  "name": "apna-rasoi",\n  "version": "1.0.0",\n  "private": true,\n  "engines": {\n    "node": "20.x"\n  },\n  "scripts": {\n    "dev": "ts-node --project tsconfig.server.json server.ts",\n    "build": "next build && tsc --project tsconfig.server.json",\n    "start": "NODE_ENV=production node dist/server.js",\n    "lint": "next lint",\n    "test": "jest --testPathPatterns=\\"unit|integration|component\\"",\n    "test:unit": "jest --testPathPatterns=\\"unit\\" --verbose",\n    "test:integration": "jest --testPathPatterns=\\"integration\\" --verbose",\n    "test:component": "jest --testPathPatterns=\\"component\\" --verbose",\n    "test:coverage": "jest --testPathPatterns=\\"unit|integration|component\\" --coverage",\n    "test:watch": "jest --testPathPatterns=\\"unit|integration|component\\" --watch",\n    "test:ci": "jest --testPathPatterns=\\"unit|integration|component\\" --coverage --ci --forceExit",\n    "test:e2e": "playwright test",\n    "test:e2e:ui": "playwright test --ui",\n    "test:e2e:headed": "playwright test --headed",\n    "test:e2e:debug": "playwright test --debug",\n    "test:e2e:report": "playwright show-report"\n  },\n  "dependencies": {\n    "@stripe/stripe-js": "^9.0.1",\n    "bcrypt": "^5.1.1",\n    "bcryptjs": "^3.0.3",\n    "cors": "^2.8.6",\n    "dotenv": "^16.4.5",\n    "express": "^5.2.1",\n    "express-rate-limit": "^7.1.5",\n    "google-auth-library": "^9.14.0",\n    "jsonwebtoken": "^9.0.2",\n    "mongoose": "^8.1.0",\n    "next": "^14.2.0",\n    "nodemailer": "^6.9.13",\n    "react": "^18.3.0",\n    "react-dom": "^18.3.0",\n    "socket.io": "^4.7.4",\n    "stripe": "^14.0.0"\n  },\n  "devDependencies": {\n    "@playwright/test": "^1.40.0",\n    "@testing-library/dom": "^10.1.0",\n    "@testing-library/jest-dom": "^6.9.1",\n    "@testing-library/react": "^16.3.2",\n    "@testing-library/user-event": "^14.6.1",\n    "@types/bcrypt": "^5.0.2",\n    "@types/bcryptjs": "^3.0.0",\n    "@types/cors": "^2.8.17",\n    "@types/jest": "^30.0.0